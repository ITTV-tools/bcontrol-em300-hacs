{
  "config": {
    "step": {
      "user": {
        "data": {
          "host": "[%key:common::config_flow::data::host%]",
          "password": "[%key:common::config_flow::data::password%]"
        },
        "data_description": {
          "host": "IP address or hostname of your B-Control EM300",
          "password": "Password configured on the meter web interface"
        }
      }
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    }
  },
  "options": {
    "step": {
      "init": {
        "data": {
          "poll_interval_seconds": "Polling interval (seconds)"
        },
        "data_description": {
          "poll_interval_seconds": "How often Home Assistant should fetch new values from the meter"
        }
      }
    }
  }
}
